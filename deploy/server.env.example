# 天九至尊 —— 生产环境变量模板
# 部署时复制到 packages/server/.env 并填入真实值：
#   cp deploy/server.env.example packages/server/.env
# 切勿提交真实 .env 到 git（已在 .gitignore 忽略）。

# 运行环境（必须为 production，启用安全校验、关闭密钥兜底）
NODE_ENV=production

# 监听端口与地址（Nginx 反代到此，仅本机访问即可）
PORT=3000
HOST=127.0.0.1

# 数据库（SQLite 文件，路径相对 packages/server）
DATABASE_URL="file:./prod.db"

# JWT 密钥（生产必填，使用强随机值；生成示例：openssl rand -base64 48）
JWT_ACCESS_SECRET=__REPLACE_WITH_STRONG_RANDOM__
JWT_REFRESH_SECRET=__REPLACE_WITH_ANOTHER_STRONG_RANDOM__
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# 允许的前端来源（生产为正式域名，逗号分隔可多个）
CORS_ORIGINS=https://skydog.skynet.fan

# 管理员后台密钥（X-Admin-Key 头，用于充值等管理接口；务必强随机）
ADMIN_API_KEY=__REPLACE_WITH_ADMIN_KEY__

# 新用户注册赠送欢乐豆
SIGNUP_BEANS=1000
